{
  "version": 1,
  "builds": [
    {
      "id": "demo-swiftui",
      "scheme": "AIKitElementsDemoApp",
      "project": "Examples/AIKitElementsDemoApp/AIKitElementsDemoApp.xcodeproj",
      "destination": "generic/platform=iOS Simulator",
      "configuration": "Debug"
    },
    {
      "id": "demo-macos",
      "scheme": "AIKitElementsDemoApp",
      "project": "Examples/AIKitElementsDemoApp/AIKitElementsDemoApp.xcodeproj",
      "destination": "platform=macOS",
      "configuration": "Debug"
    },
    {
      "id": "swift-packages",
      "scheme": "AIKit",
      "packageDir": ".",
      "destination": "platform=macOS"
    }
  ]
}
